# =============================================================
# Barodogu / Clipbaro 환경변수 (W3 2026-04-30 신설)
# =============================================================
# 사용 방법:
#   1. cp barodogu/.env.example barodogu/.env.local
#   2. 아래 값을 실제 키로 채워넣기
#   3. .env.local은 git에 커밋되지 않음 (.gitignore 등재됨)

# -------------------------------------------------------------
# Supabase 인증 (W3 ~ W4 필수)
# -------------------------------------------------------------
# 발급 위치: https://supabase.com/dashboard → 프로젝트 → Settings → API
# 미설정 시: 로그인/회원가입 페이지가 "베타 준비 중" 안내만 노출 (UI 점검 가능)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 서버 전용 (관리자 RPC, 크레딧 강제 지급 등 W4~)
# 절대 NEXT_PUBLIC_ 접두어 X (브라우저 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=

# -------------------------------------------------------------
# 결제 (Polar — 결제 유예 모드에서는 미사용)
# -------------------------------------------------------------
# false = 베타 무료 모드 (UI만 표시, 결제 불가)
# true  = 결제 활성화 (Polar 계정 + 제품 등록 후 전환)
PAYMENT_ENABLED=false
NEXT_PUBLIC_PAYMENT_ENABLED=false

# Polar (https://polar.sh → Settings → Access Tokens)
# POLAR_ACCESS_TOKEN=
# POLAR_WEBHOOK_SECRET=      # Webhook 등록 시 발급된 비밀 키
# POLAR_ENV=sandbox          # sandbox | production

# Polar 제품 ID (Polar 대시보드 → Products → 각 상품 ID 복사)
# POLAR_PRODUCT_PACK10=      # 10 크레딧 팩 product ID
# POLAR_PRODUCT_PACK30=      # 30 크레딧 팩 product ID
# POLAR_PRODUCT_PACK100=     # 100 크레딧 팩 product ID

# -------------------------------------------------------------
# 영상 렌더링 워커 (W5)
# -------------------------------------------------------------
# Fly.io Machines API 키
# FLYIO_API_TOKEN=

# Cloudflare R2 (영상 저장)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=

# -------------------------------------------------------------
# 외부 API (자체 AI 모드용 — BYOK 모드에서는 사용자가 본인 키 사용)
# -------------------------------------------------------------
# GEMINI_API_KEY=
# FAL_AI_KEY=
# CLAUDE_API_KEY=

# -------------------------------------------------------------
# 기타
# -------------------------------------------------------------
# 이메일 발송 (Resend, 매직링크·만료 알림용)
# RESEND_API_KEY=
